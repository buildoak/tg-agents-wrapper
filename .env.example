# Required
TGBOT_API_KEY=              # Telegram Bot API token from @BotFather
TGBOT_ALLOWED_USERS=        # Comma-separated Telegram user IDs (e.g., 123456,789012)
ANTHROPIC_API_KEY=           # Anthropic API key for Claude engine

# Working directory (where Claude Code runs)
WORKING_DIR=./

# Engine configuration
DEFAULT_ENGINE=claude        # "claude" or "codex"
CLAUDE_MODEL=claude-opus-4-6
CODEX_MODEL=gpt-5.4
DEFAULT_REASONING_EFFORT=high  # minimal, low, medium, high, xhigh, max

# OpenAI (required for Codex engine and Whisper transcription)
OPENAI_API_KEY=

# Voice - ElevenLabs (optional, env-gated)
ELEVENLABS_API_KEY=
DEFAULT_ELEVENLABS_VOICE_ID=  # ElevenLabs voice ID
ELEVENLABS_PUBLIC_OWNER_ID=   # ElevenLabs public owner ID for shared voices

# Voice - Kokoro (optional, local TTS)
DEFAULT_KOKORO_VOICE=af_heart

# File storage
TG_SESSION_DIR=/tmp/tg-agents-wrapper
TG_FILES_DIR=/tmp/tg-agents-wrapper-files

# Wet integration (optional - context monitoring)
WET_PORT=                    # Port for wet proxy status endpoint

# Bot display name
BOT_NAME=Bot
